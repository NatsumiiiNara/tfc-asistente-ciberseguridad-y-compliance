      "id": "ebb3d729-6eea-4914-b153-ed79201479c9",
      "name": "¿Crear Reporte?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        16,
        96
      ]
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.output;\nconst match = raw.match(/\\{[\\s\\S]*\\}/);\nif (!match) throw new Error('No se encontró JSON en la respuesta del agente');\nconst data = JSON.parse(match[0]);\nconst fecha = data.fecha || new Date().toISOString().split('T')[0];\nconst filename = `incidente_${fecha}_${data.titulo.replace(/\\s+/g, '_').toLowerCase().substring(0,30)}.md`;\nconst contenido = `# Reporte de Incidente: ${data.titulo}\\n\\n**Fecha:** ${fecha}\\n**Severidad:** ${data.severidad}\\n\\n## Descripción\\n${data.descripcion}\\n\\n## Pasos Seguidos\\n${data.pasos_seguidos}\\n\\n## Recomendaciones\\n${data.recomendaciones}\\n\\n---\\n*Generado por PhishGuard AI — MIDTECH S.A.*`;\nconst base64 = Buffer.from(contenido).toString('base64');\nreturn [{ json: { filename, contenido, base64, titulo: data.titulo, fecha, severidad: data.severidad } }];"
      },
      "id": "48d2d7a0-5ebe-431b-bf67-6e6648d56769",
      "name": "Preparar Reporte",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        240,
        0
      ]
    },
    {
      "parameters": {
        "method": "PUT",
        "url": "=https://api.github.com/repos/NatsumiiiNara/tfc-asistente-ciberseguridad-y-compliance/contents/reportes/{{ $json.filename }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Accept",
              "value": "application/vnd.github+json"
            },
            {
              "name": "X-GitHub-Api-Version",
              "value": "2022-11-28"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "message",
              "value": "=feat: reporte incidente {{ $json.titulo }} ({{ $json.fecha }})"
            },
            {
