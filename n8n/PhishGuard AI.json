    {
      "parameters": {
        "jsCode": "const github = $input.first().json;\nconst filename = $('Preparar Reporte').first().json.filename;\nconst url = github.content?.html_url || 'https://github.com/NatsumiiiNara/tfc-asistente-ciberseguridad-y-compliance/tree/main/reportes';\nreturn [{ json: { output: `✅ Reporte generado y subido a GitHub correctamente.\\n\\n📄 **Archivo:** ${filename}\\n🔗 **Ver reporte:** ${url}` } }];"
      },
